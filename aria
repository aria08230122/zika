<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>字卡机器人 · 自动回复</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        }
        body {
            background: #f5f0e8;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
        }
        .container {
            width: 100%;
            max-width: 480px;
            background: #fffaf3;
            border-radius: 32px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08), 0 8px 16px rgba(0,0,0,0.06);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 85vh;
            max-height: 800px;
        }

        /* 头部 */
        .header {
            padding: 20px 20px 12px;
            border-bottom: 1px solid #eee6db;
        }
        .header h1 {
            font-size: 20px;
            font-weight: 600;
            color: #4a3f35;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .header h1 span {
            background: #e8ddd0;
            padding: 2px 10px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 400;
            color: #5e4f40;
        }

        /* 字卡库管理区 */
        .card-library {
            background: #f4ede3;
            margin: 0 16px 16px;
            padding: 16px;
            border-radius: 24px;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        }
        .library-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            font-size: 14px;
            color: #6b5f53;
            font-weight: 500;
        }
        .library-title .count {
            background: #d9cdbc;
            padding: 2px 8px;
            border-radius: 30px;
            font-size: 12px;
            color: #3e342b;
        }
        .add-card {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }
        .add-card input {
            flex: 1;
            background: white;
            border: 1px solid #e0d5c7;
            border-radius: 40px;
            padding: 10px 16px;
            font-size: 14px;
            outline: none;
            transition: 0.2s;
            color: #2c2823;
        }
        .add-card input:focus {
            border-color: #b5a38f;
            box-shadow: 0 0 0 3px rgba(181, 163, 143, 0.2);
        }
        .add-card button {
            background: #d6c5b2;
            border: none;
            border-radius: 40px;
            padding: 0 20px;
            font-size: 14px;
            font-weight: 500;
            color: #3f362e;
            cursor: pointer;
            transition: 0.15s;
            white-space: nowrap;
            border: 1px solid #cabba9;
        }
        .add-card button:hover {
            background: #cab9a4;
        }

        /* 字卡列表（横向滚动） */
        .card-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            max-height: 90px;
            overflow-y: auto;
            padding: 4px 2px;
        }
        .card-item {
            background: white;
            border-radius: 30px;
            padding: 6px 14px 6px 16px;
            font-size: 14px;
            color: #3f362e;
            box-shadow: 0 2px 6px rgba(0,0,0,0.03);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1px solid #e2d6c8;
        }
        .card-item .delete {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #e8ddd0;
            color: #7e6e5d;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            line-height: 1;
            cursor: pointer;
            transition: 0.1s;
            border: none;
            padding: 0;
        }
        .card-item .delete:hover {
            background: #d1beab;
            color: #3f3429;
        }

        /* 聊天记录区 */
        .chat-area {
            flex: 1;
            overflow-y: auto;
            padding: 0 16px 8px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .message {
            display: flex;
            flex-direction: column;
            max-width: 85%;
        }
        .message.user {
            align-self: flex-end;
        }
        .message.bot {
            align-self: flex-start;
        }
